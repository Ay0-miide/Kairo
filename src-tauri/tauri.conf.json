{
  "productName": "KAIRO",
  "version": "2.0.0",
  "identifier": "com.kairo.scripture",
  "build": {
    "beforeDevCommand": "node server/server.js",
    "devUrl": "http://localhost:7777",
    "beforeBuildCommand": "",
    "frontendDist": "http://localhost:7777"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "KAIRO",
        "width": 1280,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../server": "server",
      "../databases": "databases"
    },
    "externalBin": []
  }
}
