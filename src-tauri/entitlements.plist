<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Node's V8 engine. Without these, the bundled `node`
         sidecar dies with SIGTRAP the moment V8 tries to JIT-compile JS,
         leaving the app with a blank webview. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required so Node + vosk-koffi can dlopen() the bundled libvosk.dylib
         (which is signed by the upstream Vosk team, not us). -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allows Node to read NODE_OPTIONS / DYLD_* envs we pass from Rust. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Microphone access for live audio capture. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
