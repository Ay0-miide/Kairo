# Dependencies
node_modules/
server/node_modules/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Sensitive config — never commit API keys
databases/settings.json

# Large binary / model files
databases/logos/ivf.faiss
databases/logos/verses.bin
databases/logos/model/
# map.json and kjv.json are required by the Tauri bundle — committed.

# Tauri build output
src-tauri/target/

# Logs
*.log
logs/

# Environment files
.env
.env.*

# Tauri updater signing key — NEVER commit the private key.
# The public key (.pub) is safe to commit; it's already baked into tauri.conf.json.
scripts/kairo-updater.key
